# Configuración del Dictado Radiológico
# Copia este archivo a .env y añade tus API keys

# Claves API de Google Gemini (Gratis en https://aistudio.google.com/app/apikey)
# Puedes añadir hasta 3 para rotar la cuota si dictas mucho
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# API Key de Groq (Whisper local)
# Regístrate gratis en: https://console.groq.com/
GROQ_API_KEY=
